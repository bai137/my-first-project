{
  "name": "teaching-lobster",
  "version": "1.0.0",
  "description": "教学龙虾 - 自动文档处理助手",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.teachinglobster.app",
    "productName": "教学龙虾",
    "copyright": "Copyright © 2026 教学龙虾",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "preload.js",
      "assets/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "pkg"
      ],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [
        "deb",
        "rpm",
        "AppImage"
      ],
      "icon": "assets/icon.png"
    }
  },
  "keywords": [
    "electron",
    "document",
    "processing",
    "education",
    "teacher"
  ],
  "author": "教学龙虾团队",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  }
}